wage_training_raw <- read_csv("data/wage_training.csv")
new_hires_raw <- read_csv("data/new_hires.csv")
# Exploratory Data Analysis -----------------------------------------------
# Overview
summary(wage_training_raw)
glimpse(wage_training_raw)
# Missings
