wage_training <- read_csv("data/wage_training.csv")
new_hires <- read_csv("data/new_hires.csv")
# EDA ---------------------------------------------------------------------
summary(wage_training)
colMeans(is.na(wage_training))
glimpse(wage_training)
var_num_check <- wage_training %>%
select_if(is.numeric) %>%
names()
var_num <- c("yos", "exp", "exp2", "age", "famsize", "nchlt5", "hoursworked")
var_cat_check <- wage_training %>%
select_if(is.character) %>%
names()
var_cat <- c("sex", "marst", "race", "speakeng", "hispanic",
"schltype", "degfield", "vetstat", "educd",
"education", "ind1990c", "occ2010c",
"region", "dchlt5", "dchlt19", "msa",
"metro", "hw")
check <- tibble(
variable = names(wage_training),
actual_class = sapply(wage_training, class)
) %>%
mutate(
expected = case_when(
variable %in% var_num ~ "numeric",
variable %in% var_cat ~ "factor/character",
TRUE ~ "unlisted / check me"
),
mismatch = case_when(
variable %in% var_numeric & !actual_class %in% c("numeric", "integer") ~ TRUE,
variable %in% var_categorical & !actual_class %in% c("factor", "character") ~ TRUE,
TRUE ~ FALSE
)
)
check <- tibble(
variable = names(wage_training),
actual_class = sapply(wage_training, class)
) %>%
mutate(
expected = case_when(
