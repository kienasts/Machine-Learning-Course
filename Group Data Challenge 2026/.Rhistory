print(miss_pct[miss_pct > 0])
# Distributions
hist(wage_training_raw$lwwage, breaks = 50)
wage_training_raw %>%
select(where(is.numeric)) %>%
pivot_longer(everything()) %>%
ggplot(aes(x = value)) +
geom_histogram() +
facet_wrap(~ name, scales = "free_x")
# Correlations
