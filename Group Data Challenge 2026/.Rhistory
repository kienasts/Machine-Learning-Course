high_cor    <- findCorrelation(cor_mat, cutoff = 0.95)
if (length(high_cor) > 0) {
X_train     <- X_train[,     -high_cor]
X_test      <- X_test[,      -high_cor]
X_new_hires <- X_new_hires[, -high_cor]
}
